# ==============================================================
# FEDERATED LEARNING SKIN CANCER DETECTION — .gitignore
# ==============================================================

# --------------------------------------------------------------
# SECRETS & ENVIRONMENT VARIABLES
# --------------------------------------------------------------
.env
.env.local
.env.*.local
.env.production
# Keep .env.example files (they document required vars)
!.env.example

# --------------------------------------------------------------
# NODE / JAVASCRIPT
# --------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Lock files (committed for reproducibility — uncomment to exclude)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Build outputs
client/dist/
desktop-app/release/
/dist/
/build/

# Vite
.vite/

# --------------------------------------------------------------
# PYTHON
# --------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
.Python

# Virtual environments
env/
venv/
ENV/
.venv/
my-env/
.env/
pyenv/

# Distribution / packaging
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Pytest
.pytest_cache/
.tox/
htmlcov/

# --------------------------------------------------------------
# ML MODEL WEIGHTS & LARGE FILES
# --------------------------------------------------------------
# Uncomment the lines below if you want to exclude model weights
# (recommend using Git LFS instead for large .pt / .h5 files)
# *.pt
# *.pth
# *.h5
# *.pkl
# *.ckpt
# *.model

# Local FL client weights (per-hospital, never share)
desktop-app/fl_client/local_weights/

# FL server temporary client update buffers
fl-server/client_updates/

# --------------------------------------------------------------
