# Server Configuration
PORT=3001
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/skin-cancer-db
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/skin-cancer-db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# Python ML API
ML_API=http://localhost:5000

# Federated Learning Server
FL_API=http://localhost:6000

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# AWS S3 (for storing images)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=skin-cancer-bucket
AWS_REGION=us-east-1

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# Logging
LOG_LEVEL=debug

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Deployment
NODE_ENV=production
